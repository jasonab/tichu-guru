root = true

[*.{kt,kts}]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
ktlint_code_style = ktlint_official

# default IntelliJ IDEA style, same as alphabetical, but with "java", "javax", "kotlin" and alias imports in the end of the imports list
ij_kotlin_imports_layout = *, java.**, javax.**, kotlin.**, ^

# it's just too many commas
ij_kotlin_allow_trailing_comma_on_call_site = false
ktlint_chain_method_rule_force_multiline_when_chain_operator_count_greater_or_equal_than = 5
ktlint_class_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 3
