<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardTichu1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardTichu3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GT"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardHandScore1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+50"/>
        <View
            android:background="#ff909090"
            android:layout_width="match_parent"
            android:layout_height="2dp"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardTotalScore1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="350"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardHandScore2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+50"/>
        <View
            android:background="#ff909090"
            android:layout_width="match_parent"
            android:layout_height="2dp"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardTotalScore2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="350"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardTichu2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/scorecardTichu4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GT"/>
    </LinearLayout>
</LinearLayout>
