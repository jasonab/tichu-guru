<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:gravity="center_horizontal"
            android:id="@+id/scorecardName1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stephanie"/>
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:gravity="center_horizontal"
            android:id="@+id/scorecardName3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Corey"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""/>
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:gravity="center_horizontal"
            android:id="@+id/scorecardName2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stephanie Kington"/>
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:gravity="center_horizontal"
            android:id="@+id/scorecardName4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zoe"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/scorecardList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    <Button
        android:id="@+id/scorecardDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Last Hand"/>
</LinearLayout>
