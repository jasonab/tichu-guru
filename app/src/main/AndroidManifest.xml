<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="4"
    android:versionName="1.03">
    <uses-sdk android:targetSdkVersion="30"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <application
        android:label="@string/app_name"
        android:icon="@drawable/icon"
        android:name="com.tichuguru.TGApp"
        android:theme="@style/AppTheme">
        <activity
            android:label="@string/app_name"
            android:name="com.tichuguru.TGActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
            android:label="Current Score"
            android:name="CurHandActivity"/>
        <activity
            android:label="Scorecard"
            android:name="ScorecardActivity"/>
        <activity
            android:label="Stats"
            android:name="StatsActivity"/>
        <activity
            android:label="All Games"
            android:name="AllGamesActivity"/>
        <activity
            android:label="New Game"
            android:name="NewGameActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:label="Score Hand"
            android:name="ScoreHandActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:label="Statistics"
            android:name="StatsListActivity"
            android:screenOrientation="portrait"/>
    </application>
</manifest>
