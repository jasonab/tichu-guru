<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:label="@string/app_name"
        android:icon="@drawable/icon"
        android:name=".TGApp"
        android:theme="@style/AppTheme">
        <activity
            android:label="@string/app_name"
            android:name=".TGActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
            android:label="New Game"
            android:name=".NewGameActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>
        <activity
            android:label="Score Hand"
            android:name=".ScoreHandActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>
        <activity
            android:label="Statistics"
            android:name=".StatsListActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>
        <activity
            android:label="Current Hand"
            android:name=".CurHandActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>
    </application>
</manifest>
